{
  "name": "@design-md/tokens-platform",
  "version": "2.3.0",
  "description": "Design Tokens Platform v2.3.0 - Multi-platform token export with Style Dictionary v4+",
  "private": true,
  "type": "module",
  "scripts": {
    "tokens:build": "node scripts/build-tokens.js",
    "tokens:build:watch": "node scripts/build-tokens.js --watch",
    "tokens:lint": "node scripts/lint-tokens.js",
    "tokens:validate": "python3 scripts/validate-schema.py && python3 scripts/agents/token-schema-validator.py --full",
    "tokens:diff": "python3 scripts/agents/token-diff-reporter.py",
    "tokens:migrate": "python3 scripts/agents/token-migrate.py",
    "validate": "python3 scripts/validate.py",
    "test": "python3 scripts/test.py",
    "maintain": "python3 scripts/robust-maintain.py"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "white-label",
    "style-dictionary",
    "wcag",
    "accessibility"
  ],
  "author": "Design.MD Team",
  "license": "MIT",
  "dependencies": {
    "style-dictionary": "^4.0.0"
  },
  "devDependencies": {
    "chalk": "^5.3.0",
    "lodash-es": "^4.17.21"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
