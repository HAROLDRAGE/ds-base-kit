{
  "name": "@design-md/tokens-platform",
  "version": "2.3.0",
  "description": "Design Tokens Platform v2.3.0 - dependency-free multi-platform DTCG export",
  "private": true,
  "type": "module",
  "scripts": {
    "tokens:build": "node scripts/build-token-exports.js",
    "tokens:build:watch": "node scripts/build-token-exports.js --watch",
    "tokens:metadata": "python3 scripts/enrich-token-metadata.py",
    "tokens:lint": "node scripts/lint-tokens.js",
    "tokens:validate": "python3 scripts/validate-schema.py && python3 scripts/agents/token-schema-validator.py --full",
    "tokens:diff": "python3 scripts/agents/token-diff-reporter.py",
    "tokens:migrate": "python3 scripts/agents/token-migrate.py",
    "tokens:deprecate": "python3 scripts/governance/deprecation-policy.py",
    "tokens:coverage": "python3 scripts/governance/coverage-matrix.py",
    "tokens:health": "python3 scripts/governance/health-monitor.py",
    "tokens:govern": "npm run tokens:deprecate && npm run tokens:coverage && npm run tokens:health",
    "validate": "python3 scripts/validate.py",
    "test": "python3 scripts/test.py"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "white-label",
    "dtcg",
    "wcag",
    "accessibility"
  ],
  "author": "Design.MD Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
