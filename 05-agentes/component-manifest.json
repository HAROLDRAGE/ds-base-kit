{
  "$schema": "./manifest.schema.json",
  "name": "Design.MD White Label — IA Ready",
  "version": "2.2.0",
  "contract": "./AGENT-CONTRACT.md",
  "changelog": "../CHANGELOG.md",
  "brands": [
    "promptea",
    "nova",
    "ocean"
