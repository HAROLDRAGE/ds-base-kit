{
  "$schema": "./manifest.schema.json",
  "name": "Design.MD White Label — IA Ready",
  "version": "2.0.0",
  "contract": "./AGENT-CONTRACT.md",
  "changelog": "../CHANGELOG.md",
  "brands": [
    "promptea",
    "nova",
    "ocean"
  ],
  "themes": [
    "dark",
    "light"
  ],
  "tokens": {
    "semantic": {
      "color.bg": {
        "use": "Fondo base de página",
        "not_for": "Texto"
      },
      "color.surface": {
        "use": "Tarjetas, paneles, inputs",
        "not_for": "Texto"
      },
      "color.text": {
        "use": "Texto principal",
        "not_for": "Fondos"
      },
      "color.muted": {
        "use": "Texto secundario, ayudas",
        "not_for": "Texto crítico o legal"
      },
      "color.action": {
        "use": "Acciones principales, enlaces, foco",
        "not_for": "Fondos extensos ni texto de párrafo"
      },
      "color.on-action": {
        "use": "Texto/icono sobre color.action",
        "not_for": "Cualquier otro fondo"
      },
      "color.focus": {
        "use": "Anillo de foco visible",
        "not_for": "Decoración"
      },
      "color.danger": {
        "use": "Errores: siempre con icono + palabra",
        "not_for": "Énfasis genérico"
      },
      "color.success": {
        "use": "Confirmaciones: siempre con icono + palabra",
        "not_for": "Énfasis genérico"
      },
      "color.border": {
        "use": "Bordes y divisores",
        "not_for": "Texto"
      },
      "typography.font-family-base": {
        "value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif",
        "use": "Tipografía de cuerpo y general"
      },
      "typography.font-family-mono": {
        "value": "'Fira Code', 'Courier New', 'Courier', monospace",
        "use": "Código, snippets, componentes técnicos"
      },
      "typography.font-weight-light": {
        "value": "300",
        "use": "Textos menos enfatizados"
      },
      "typography.font-weight-regular": {
        "value": "400",
        "use": "Cuerpo de texto estándar"
      },
      "typography.font-weight-medium": {
        "value": "500",
        "use": "Énfasis moderado, labels"
      },
      "typography.font-weight-semibold": {
        "value": "600",
        "use": "Énfasis fuerte, botones"
      },
      "typography.font-weight-bold": {
        "value": "700",
        "use": "Muy enfatizado, headings"
      },
      "typography.font-weight-extrabold": {
        "value": "800",
        "use": "Máximo énfasis, títulos principales"
      },
      "typography.size-xs": {
        "value": "0.75rem",
        "use": "Ayudas, badges"
      },
      "typography.size-sm": {
        "value": "0.875rem",
        "use": "Labels, pequeño"
      },
      "typography.size-base": {
        "value": "1rem",
        "use": "Cuerpo estándar"
      },
      "typography.size-lg": {
        "value": "1.125rem",
        "use": "Subtítulos"
      },
      "typography.size-xl": {
        "value": "1.25rem",
        "use": "Heading grande"
      },
      "typography.size-2xl": {
        "value": "1.5rem",
        "use": "Heading mayor"
      },
      "typography.size-3xl": {
        "value": "1.875rem",
        "use": "Heading h3"
      },
      "typography.size-4xl": {
        "value": "2.25rem",
        "use": "Heading h2"
      },
      "typography.size-5xl": {
        "value": "3rem",
        "use": "Heading h1 grande"
      },
      "typography.line-height-tight": {
        "value": "1.2",
        "use": "Headings compactos"
      },
      "typography.line-height-normal": {
        "value": "1.5",
        "use": "Cuerpo estándar"
      },
      "typography.line-height-relaxed": {
        "value": "1.75",
        "use": "Párrafos largos"
      },
      "typography.line-height-loose": {
        "value": "2",
        "use": "Muy espaciado, poesía"
      },
      "typography.letter-spacing-tight": {
        "value": "-0.02em",
        "use": "Display headings"
      },
      "typography.letter-spacing-normal": {
        "value": "0",
        "use": "Estándar"
      },
      "typography.letter-spacing-wide": {
        "value": "0.05em",
        "use": "Labels, caps"
      },
      "typography.letter-spacing-wider": {
        "value": "0.1em",
        "use": "Mayúsculas enfatizado"
      },
      "space.0": {
        "value": "0px",
        "use": "Sin espaciado"
      },
      "space.1": {
        "value": "4px",
        "use": "Separación mínima icono-texto"
      },
      "space.2": {
        "value": "8px",
        "use": "Interno compacto"
      },
      "space.3": {
        "value": "12px",
        "use": "Interno de controles"
      },
      "space.4": {
        "value": "16px",
        "use": "Padding estándar"
      },
      "space.5": {
        "value": "20px",
        "use": "Espaciado medio"
      },
      "space.6": {
        "value": "24px",
        "use": "Entre bloques"
      },
      "space.8": {
        "value": "32px",
        "use": "Entre secciones"
      },
      "space.10": {
        "value": "40px",
        "use": "Separación grande"
      },
      "space.12": {
        "value": "48px",
        "use": "Separación muy grande"
      },
      "space.16": {
        "value": "64px",
        "use": "Separación entre secciones principales"
      },
      "radius.none": {
        "value": "0",
        "use": "Sin redondeo"
      },
      "radius.sm": {
        "value": "4px",
        "use": "Badges, inputs pequeños"
      },
      "radius.md": {
        "value": "8px",
        "use": "Botones, inputs"
      },
      "radius.lg": {
        "value": "12px",
        "use": "Tarjetas, modales"
      },
      "radius.xl": {
        "value": "16px",
        "use": "Paneles grandes"
      },
      "radius.2xl": {
        "value": "20px",
        "use": "Componentes prominentes"
      },
      "radius.pill": {
        "value": "999px",
        "use": "Pills, avatares"
      },
      "border.width-hairline": {
        "value": "0.5px",
        "use": "Divisores sutiles"
      },
      "border.width-thin": {
        "value": "1px",
        "use": "Bordes estándar"
      },
      "border.width-base": {
        "value": "2px",
        "use": "Bordes destacados"
      },
      "border.width-thick": {
        "value": "4px",
        "use": "Énfasis en bordes"
      },
      "border.style-solid": {
        "value": "solid",
        "use": "Bordes sólidos"
      },
      "border.style-dashed": {
        "value": "dashed",
        "use": "Áreas opcionales"
      },
      "border.style-dotted": {
        "value": "dotted",
        "use": "Bordes sutiles"
      },
      "shadow.sm": {
        "value": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
        "use": "Elevación mínima"
      },
      "shadow.md": {
        "value": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
        "use": "Elevación media"
      },
      "shadow.lg": {
        "value": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
        "use": "Elevación grande"
      },
      "shadow.xl": {
        "value": "0 20px 25px -5px rgb(0 0 0 / 0.1), 0 8px 10px -6px rgb(0 0 0 / 0.1)",
        "use": "Elevación muy grande"
      },
      "shadow.2xl": {
        "value": "0 25px 50px -12px rgb(0 0 0 / 0.25)",
        "use": "Elevación máxima"
      },
      "motion.fast": {
        "value": "120ms",
        "use": "Hover, focus"
      },
      "motion.base": {
        "value": "240ms",
        "use": "Aparición, expansión"
      },
      "motion.slow": {
        "value": "400ms",
        "use": "Transiciones complejas"
      },
      "motion.easing-linear": {
        "value": "linear",
        "use": "Movimiento constante"
      },
      "motion.easing-in": {
        "value": "cubic-bezier(0.4, 0, 1, 1)",
        "use": "Entrada suave"
      },
      "motion.easing-out": {
        "value": "cubic-bezier(0, 0, 0.2, 1)",
        "use": "Salida suave"
      },
      "motion.easing-in-out": {
        "value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "use": "Entrada y salida suaves"
      },
      "media.aspect-square": {
        "value": "1 / 1",
        "use": "Imágenes cuadradas"
      },
      "media.aspect-video": {
        "value": "16 / 9",
        "use": "Imágenes panorámicas"
      },
      "media.aspect-3-2": {
        "value": "3 / 2",
        "use": "Fotografías estándar"
      },
      "media.object-fit-cover": {
        "value": "cover",
        "use": "Rellenar sin distorsión"
      },
      "media.object-fit-contain": {
        "value": "contain",
        "use": "Ajustar dentro manteniendo proporción"
      }
    },
    "values": {
      "promptea": {
        "dark": {
          "bg": "#0B0E11",
          "surface": "#14181D",
          "text": "#E8ECF1",
          "muted": "#9AA5B1",
          "action": "#7CE83A",
          "on-action": "#0B0E11",
          "focus": "#7CE83A",
          "danger": "#F87171",
          "success": "#4ADE80",
          "border": "#2A3138"
        },
        "light": {
          "bg": "#FFFFFF",
          "surface": "#F4F6F8",
          "text": "#1A2027",
          "muted": "#5A6572",
          "action": "#2E7D0F",
          "on-action": "#FFFFFF",
          "focus": "#2E7D0F",
          "danger": "#B91C1C",
          "success": "#15803D",
          "border": "#D7DDE3"
        }
      },
      "nova": {
        "dark": {
          "bg": "#0D0B14",
          "surface": "#171322",
          "text": "#ECE9F4",
          "muted": "#A49DB8",
          "action": "#A78BFA",
          "on-action": "#0D0B14",
          "focus": "#A78BFA",
          "danger": "#F87171",
          "success": "#4ADE80",
          "border": "#2E2840"
        },
        "light": {
          "bg": "#FFFFFF",
          "surface": "#F6F4FB",
          "text": "#1D1830",
          "muted": "#5D5674",
          "action": "#6D28D9",
          "on-action": "#FFFFFF",
          "focus": "#6D28D9",
          "danger": "#B91C1C",
          "success": "#15803D",
          "border": "#DDD8EA"
        }
      },
      "ocean": {
        "dark": {
          "bg": "#081018",
          "surface": "#0F1B26",
          "text": "#E6EEF5",
          "muted": "#8FA3B5",
          "action": "#38BDF8",
          "on-action": "#081018",
          "focus": "#38BDF8",
          "danger": "#F87171",
          "success": "#4ADE80",
          "border": "#22323F"
        },
        "light": {
          "bg": "#FFFFFF",
          "surface": "#F2F7FB",
          "text": "#122130",
          "muted": "#4E6478",
          "action": "#0369A1",
          "on-action": "#FFFFFF",
          "focus": "#0369A1",
          "danger": "#B91C1C",
          "success": "#15803D",
          "border": "#D3E0EA"
        }
      }
    }
  },
  "rules": {
    "primary_button_per_view": 1,
    "raw_values_forbidden": true,
    "state_not_only_color": true,
    "reduced_motion_respected": true,
    "contrast": {
      "text": "4.5:1",
      "large_text_and_ui": "3:1"
    }
  },
  "components": [
    {
      "name": "button",
      "atomic_level": "atom",
      "when_to_use": "Acciones que ejecutan algo (guardar, enviar).",
      "when_not_to_use": "Navegación entre páginas: usa link.",
      "variants": [
        "primary",
        "secondary",
        "ghost",
        "danger"
      ],
      "states": [
        "default",
        "hover",
        "focus",
        "active",
        "disabled",
        "loading"
      ],
      "a11y": {
        "role": "button",
        "focus_ring": "color.focus 2px + offset",
        "loading": "aria-busy=true, texto persiste"
      },
      "keyboard": {
        "Enter/Space": "activa",
        "Tab": "foco visible"
      },
      "tokens_used": [
        "color.action",
        "color.on-action",
        "space.3",
        "space.4",
        "radius.md",
        "motion.fast"
      ]
    },
    {
      "name": "link",
      "atomic_level": "atom",
      "when_to_use": "Navegación a otra vista o recurso.",
      "when_not_to_use": "Ejecutar acciones: usa button.",
      "variants": [
        "inline",
        "standalone"
      ],
      "states": [
        "default",
        "hover",
        "focus",
        "visited"
      ],
      "a11y": {
        "texto": "autoexplicativo, nunca 'clic aquí'",
        "subrayado": "visible en contexto de párrafo"
      },
      "keyboard": {
        "Enter": "navega",
        "Tab": "foco visible"
      },
      "tokens_used": [
        "color.action",
        "motion.fast"
      ]
    },
    {
      "name": "input",
      "atomic_level": "atom",
      "when_to_use": "Entrada de texto de una línea.",
      "when_not_to_use": "Texto largo: usa textarea. Opciones cerradas: usa select.",
      "variants": [
        "text",
        "email",
        "password",
        "search"
      ],
      "states": [
        "default",
        "hover",
        "focus",
        "disabled",
        "error"
      ],
      "a11y": {
        "label": "siempre visible y asociado (for/id)",
        "error": "icono + mensaje vinculado con aria-describedby"
      },
      "keyboard": {
        "Tab": "foco visible",
        "Escape": "limpia en type=search"
      },
      "tokens_used": [
        "color.surface",
        "color.text",
        "color.border",
        "color.danger",
        "space.3",
        "radius.md",
        "motion.fast"
      ]
    },
    {
      "name": "badge",
      "atomic_level": "atom",
      "when_to_use": "Estado o metadato corto (Nuevo, Beta, Error).",
      "when_not_to_use": "Acciones o navegación.",
      "variants": [
        "neutral",
        "success",
        "danger",
        "brand"
      ],
      "states": [
        "default"
      ],
      "a11y": {
        "estado": "icono o palabra además del color, nunca solo color"
      },
      "keyboard": {},
      "tokens_used": [
        "color.surface",
        "color.success",
        "color.danger",
        "space.1",
        "space.2",
        "radius.pill"
      ]
    },
    {
      "name": "field",
      "atomic_level": "molecule",
      "when_to_use": "Label + input + ayuda/error como unidad de formulario.",
      "when_not_to_use": "Input suelto sin label.",
      "variants": [
        "default",
        "with-help",
        "with-error"
      ],
      "states": [
        "default",
        "focus",
        "disabled",
        "error"
      ],
      "a11y": {
        "composición": "label[for] + input[id] + p[id] referenciado por aria-describedby"
      },
      "keyboard": {
        "Tab": "orden lógico label→input"
      },
      "tokens_used": [
        "color.text",
        "color.muted",
        "color.danger",
        "space.2"
      ]
    },
    {
      "name": "alert",
      "atomic_level": "molecule",
      "when_to_use": "Mensajes de estado del sistema (info, éxito, error).",
      "when_not_to_use": "Confirmaciones que interrumpen: usa modal.",
      "variants": [
        "info",
        "success",
        "warning",
        "danger"
      ],
      "states": [
        "default",
        "dismissible"
      ],
      "a11y": {
        "role": "status para info/éxito, alert para error",
        "contenido": "icono + palabra clave + texto"
      },
      "keyboard": {
        "Escape": "cierra si es dismissible"
      },
      "tokens_used": [
        "color.surface",
        "color.danger",
        "color.success",
        "space.4",
        "radius.lg"
      ]
    },
    {
      "name": "card",
      "atomic_level": "molecule",
      "when_to_use": "Agrupar contenido relacionado en una superficie.",
      "when_not_to_use": "Layout de página completo.",
      "variants": [
        "default",
        "interactive"
      ],
      "states": [
        "default",
        "hover",
        "focus"
      ],
      "a11y": {
        "interactiva": "un solo enlace/acción principal, foco en la tarjeta completa"
      },
      "keyboard": {
        "Enter": "activa si es interactiva"
      },
      "tokens_used": [
        "color.surface",
        "color.border",
        "space.4",
        "radius.lg",
        "motion.fast"
      ]
    },
    {
      "name": "navbar",
      "atomic_level": "organism",
      "when_to_use": "Navegación principal del producto.",
      "when_not_to_use": "Navegación local de sección: usa tabs.",
      "variants": [
        "default",
        "with-actions"
      ],
      "states": [
        "default",
        "scrolled"
      ],
      "a11y": {
        "landmark": "nav con aria-label",
        "actual": "aria-current='page' en el ítem activo"
      },
      "keyboard": {
        "Tab": "recorre ítems en orden visual"
      },
      "tokens_used": [
        "color.bg",
        "color.border",
        "space.4",
        "space.5"
      ]
    },
    {
      "name": "modal",
      "atomic_level": "organism",
      "when_to_use": "Tareas que requieren foco exclusivo y decisión.",
      "when_not_to_use": "Información pasiva: usa alert o card.",
      "variants": [
        "default",
        "confirm",
        "danger"
      ],
      "states": [
        "closed",
        "open",
        "loading"
      ],
      "a11y": {
        "role": "dialog aria-modal=true",
        "focus": "trap dentro; al cerrar vuelve al disparador",
        "título": "aria-labelledby"
      },
      "keyboard": {
        "Escape": "cierra",
        "Tab": "cíclico dentro del modal"
      },
      "tokens_used": [
        "color.surface",
        "radius.lg",
        "space.5",
        "motion.base"
      ]
    }
  ]
}
